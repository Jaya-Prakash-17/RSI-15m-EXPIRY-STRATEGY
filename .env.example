# ================================================
# RSI Breakout Bot — Environment Variables
# ================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the real .env file (it's in .gitignore)
# ================================================

# ──── Groww Broker API ────
# Get your API key from Groww Developer Console
GROWW_API_KEY=your_groww_api_jwt_token_here
GROWW_API_SECRET=your_groww_api_secret_here
GROWW_MOCK_MODE=False

# ──── Telegram Notifications ────
# 1. Open Telegram → search @BotFather → /newbot → copy BOT_TOKEN
# 2. Send any message to your new bot
# 3. Open: https://api.telegram.org/botYOUR_TOKEN/getUpdates
# 4. Copy the chat.id number from the JSON response
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
